function renderizar(nodoId) {
    const nodo = historia[nodoId];
    const pantalla = document.getElementById('pantalla');
    let html = `<div class="nodo-texto">${nodo.texto}</div><div class="botones">`;
    
    nodo.opciones.forEach(opt => {
        html += `<button onclick="renderizar('${opt.destino}')">${opt.texto}</button>`;
    });
    
    html += `</div>`;
    pantalla.innerHTML = html;
}

// Iniciar la narrativa

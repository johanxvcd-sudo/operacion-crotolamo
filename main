<div class="container">
    <h1>Expediente: Operación Barbarroja</h1>
    
    <div id="inventory">
        <div class="stat">MUNICIÓN AP (Perforante)<span id="ap" class="val">0</span></div>
        <div class="stat">MUNICIÓN HE (Explosiva)<span id="he" class="val">0</span></div>
        <div class="stat">VIDA MOTOR (Límite 100h)<span id="motor" class="val">0</span>h</div>
    </div>

    <div id="game">
        <div id="text" class="story-box"></div>
        <div id="diary" class="diary-entry" style="display:none;"></div>
        <div id="choices" class="btn-group"></div>
    </div>
</div>

<script>
// Estado inicial basado en fuentes técnicas
let state = { ap: 4, he: 11, motor: 100 }; // 15% de munición real [1, 2]

const nodes = {
    inicio: {
        text: "MAYO 1941. Inteligencia confirma el despliegue alemán. El Plan de Mayo de Timoshenko y Zhúkov propone un ataque preventivo inmediato con 152 divisiones [5, 6].",
        diary: "Hans (22 de junio): 'Marchamos hacia el este. El polvo se vuelve óxido en mi boca... tragamos Rusia con cada aliento' [7].",
        options: [
            { text: "Lanzar 'Relámpago Rojo' (Ucronía Soviética)", next: "soviet_attack" },
            { text: "Mantener defensa (Historia Real)", next: "barbarossa_real" }
        ]
    },
    soviet_attack: {
        text: "GOLPE PREVENTIVO. Logras sorpresa, pero la logística es un caos. El 50% de tus tanques fallan mecánicamente antes de ver al enemigo [1, 2].",
        options: [
            { text: "Capturar petróleo en Rumanía (-40h motor)", next: "victory_oil", costM: 40 },
            { text: "Agotar fuerzas en choque frontal", next: "failure_attrition" }
        ]
    },
    barbarossa_real: {
        text: "AGOSTO 1941. La Wehrmacht avanza 400km/semana. Hitler exige Ucrania, pero Guderian insiste en Moscú para partir la URSS en dos [8, 9].",
        diary: "Hans (3 de julio): 'Carl cayó... su sangre se secó en mis manos. Ya no sé si está vivo' [10, 11].",
        options: [
            { text: "Prioridad Moscú (Ucronía Alemana)", next: "moscow_path" },
            { text: "Prioridad Kiev (Camino Real)", next: "kiev_path" }
        ]
    },
    moscow_path: {
        text: "MOSCÚ CAE en septiembre. Stalin activa 'Tankograd' en los Urales: 1,000 tanques/mes fabricados por mujeres en naves bajo lonas a -40°C [12, 13].",
        options: [{ text: "Ver el final de la historia", next: "myth" }]
    },
    kiev_path: {
        text: "VICTORIA EN KIEV (600,000 prisioneros). Pero el frío llega a -45°C. El combustible se hiela y no hay ropa de invierno [14, 15].",
        diary: "Hans (12 de agosto): 'Vimos el infierno... un barranco lleno de civiles ejecutados. Estoy avergonzado de usar este uniforme' [16, 17].",
        options: [
            { text: "Aplicar 'Decreto Barbarroja' (Rigor)", next: "partisan_war" },
            { text: "Priorizar logística invernal", next: "stalling" }
        ]
    },
    partisan_war: {
        text: "GUERRA DE EXTERMINIO. Las órdenes criminales de Keitel eliminan la justicia militar. La población se une masivamente a los partisanos [18, 19].",
        options: [{ text: "Acceder al archivo histórico", next: "myth" }]
    },
    myth: {
        text: "1950. Los generales supervivientes crean el 'Mito de la Wehrmacht limpia', culpando solo a Hitler para facilitar el rearme en la Guerra Fría [4, 20].",
        options: [{ text: "Reiniciar Simulación", next: "inicio", reset: true }]
    },
    victory_oil: { text: "Capturas Ploiesti. Alemania colapsa sin combustible en 1942.", options: [{ text: "Reiniciar", next: "inicio", reset: true }] },
    failure_attrition: { text: "Colapso mecánico total. La Wehrmacht te aniquila.", options: [{ text: "Reiniciar", next: "inicio", reset: true }] },
    stalling: { text: "Frente estabilizado en el río Mius. Preparación para 1942.", options: [{ text: "Reiniciar", next: "inicio", reset: true }] }
};

function updateUI() {
    document.getElementById('ap').innerText = state.ap;
    document.getElementById('he').innerText = state.he;
    document.getElementById('motor').innerText = state.motor;
}

function render(nodeId) {
    const node = nodes[nodeId];
    if (node.reset) { state = { ap: 4, he: 11, motor: 100 }; }
    
    updateUI();
    document.getElementById('text').innerHTML = node.text;
    
    const diaryEl = document.getElementById('diary');
    if (node.diary) { diaryEl.innerHTML = node.diary; diaryEl.style.display = 'block'; }
    else { diaryEl.style.display = 'none'; }

    const choicesEl = document.getElementById('choices');
    choicesEl.innerHTML = '<span class="label">TRANSICIÓN OPERACIONAL:</span>';
    
    node.options.forEach(opt => {
        const canPay = (opt.costM || 0) <= state.motor;
        const btn = document.createElement('button');
        btn.innerHTML = opt.text + (canPay ? "" : " (Fallo Mecánico)");
        btn.disabled = !canPay;
        btn.onclick = () => {
            state.motor -= (opt.costM || 0);
            render(opt.next);
        };
        choicesEl.appendChild(btn);
    });
}

render('inicio');
</script>
</body>
</html>

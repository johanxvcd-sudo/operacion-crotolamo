<body>
<div class="container">
    <h1>Expediente Barbarroja</h1>
    
    <!-- Imagen que cambia según la decisión -->
    <div id="visual-aid"></div>

    <div id="inventory">
        <div class="stat">MUNICIÓN<span id="ammo" class="val">4/11</span></div>
        <div class="stat">MOTOR<span id="motor" class="val">100</span>h</div>
        <div class="stat">MORAL<span id="moral" class="val">100</span>%</div>
        <div class="stat">RESISTENCIA<span id="res" class="val">0</span>%</div>
    </div>

    <div id="game">
        <div id="text" class="story-box"></div>
        <div id="choices" class="btn-group"></div>
    </div>
</div>

<script>
let state = { motor: 100, moral: 100, res: 0 };

const nodes = {
    inicio: {
        text: "JUNIO 1941. El alto mando nazi presenta el <b>Decreto Barbarroja</b>. La guerra será de exterminio. Las ejecuciones no serán asunto de tribunales, sino de acción organizada.",
        image: "https://upload.wikimedia.org/wikipedia/commons/e/e0/Bundesarchiv_Bild_183-B0627-0001-014%2C_Russland%2C_Vormarsch_infanterie.jpg", 
        options: [
            { text: "Aceptar Decreto (Aniquilación)", next: "decreto_si", modMoral: -20, modRes: +30 },
            { text: "Mantener Disciplina (Justicia Militar)", next: "decreto_no", modMoral: +10, modRes: -5 }
        ]
    },
    decreto_si: {
        text: "GUERRA DE EXTERMINIO. 'Vimos un barranco lleno de civiles ejecutados', escribe Hans. El odio partisano explota en la retaguardia.",
        image: "https://upload.wikimedia.org/wikipedia/commons/0/07/Bundesarchiv_Bild_101I-287-0872-27%2C_Russland%2C_Exekution_von_Partisanen.jpg",
        options: [{ text: "Avanzar a Moscú", next: "ucro_moscu", costM: 40 }]
    },
    decreto_no: {
        text: "DISCIPLINA. Ignoras el decreto para evitar el caos moral. Los partisanos son menos activos, pero el OKW cuestiona tu lealtad política.",
        image: "https://upload.wikimedia.org/wikipedia/commons/5/52/Bundesarchiv_Bild_101I-136-0882-12%2C_Russland%2C_Vormarsch_auf_staubiger_Strasse.jpg",
        options: [{ text: "Girar al sur (Kiev)", next: "kiev_path" }]
    },
    ucro_moscu: {
        text: "MOSCÚ CAE. Las torres del Kremlin están bajo control alemán en septiembre. Pero la industria de Stalin se ha movido a los Urales (Tankograd).",
        image: "https://upload.wikimedia.org/wikipedia/commons/5/57/Panzer_III_in_Russia.jpg",
        options: [{ text: "Final: El Mito de la Wehrmacht", next: "myth" }]
    },
    kiev_path: {
        text: "CERCO DE KIEV. 600.000 prisioneros. Pero el tiempo se acaba. La nieve empieza a cubrir los tanques y el barro detiene los suministros.",
        image: "https://upload.wikimedia.org/wikipedia/commons/7/75/Bundesarchiv_Bild_101I-268-0174-02%2C_Russland%2C_Vormarsch_in_Schlamm.jpg",
        options: [{ text: "Ver Epílogo", next: "myth" }]
    },
    myth: {
        text: "1950. Generales como Halder borran las huellas de las órdenes criminales. Crean el mito de que el ejército fue ajeno al Holocausto.",
        image: "https://upload.wikimedia.org/wikipedia/commons/c/c8/Franz_Halder.jpg",
        options: [{ text: "Reiniciar", next: "inicio", reset: true }]
    }
};

function render(nodeId) {
    const node = nodes[nodeId];
    if (node.reset) state = { motor: 100, moral: 100, res: 0 };
    
    document.getElementById('visual-aid').style.backgroundImage = `url(${node.image})`;
    document.getElementById('text').innerHTML = node.text;
    document.getElementById('motor').innerText = state.motor;
    document.getElementById('moral').innerText = state.moral;
    document.getElementById('res').innerText = state.res;

    const choicesEl = document.getElementById('choices');
    choicesEl.innerHTML = '';
    node.options.forEach(opt => {
        const btn = document.createElement('button');
        btn.innerHTML = opt.text;
        btn.onclick = () => {
            state.motor -= (opt.costM || 0);
            state.moral += (opt.modMoral || 0);
            state.res += (opt.modRes || 0);
            render(opt.next);
        };
        choicesEl.appendChild(btn);
    });
}
render('inicio');
</script>
</body>
